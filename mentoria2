<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akasha Hub | Mentoria — Apostilas</title>
  <link rel="icon" type="image/webp" href="https://res.cloudinary.com/dcbarseus/image/upload/v1773707211/IMG_20260104_135834_828_nsimow.webp">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Josefin+Sans:wght@100;300;400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #06050a; --gold: #c9a227; --gold-light: #f0d078;
      --gold-border: rgba(201,162,39,.28); --white: #f5f0e8;
      --muted: rgba(245,240,232,.38); --card: rgba(255,255,255,.022);
      --purple: #7c4dbd; --purple-lt: #a67fdc;
      --purple-border: rgba(166,127,220,.3);
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body {
      background:var(--bg); color:var(--white);
      font-family:'Josefin Sans',sans-serif; font-weight:300;
      min-height:100vh; overflow-x:hidden;
    }
    body::before {
      content:''; position:fixed; top:-10%; left:50%; transform:translateX(-50%);
      width:800px; height:700px;
      background:radial-gradient(ellipse, rgba(124,77,189,.08) 0%, rgba(201,162,39,.04) 50%, transparent 70%);
      pointer-events:none; animation:breathe 12s ease-in-out infinite;
    }
    @keyframes breathe { 0%,100%{opacity:.6;} 50%{opacity:1;} }

    /* NAV */
    nav {
      position:fixed; top:0; left:0; right:0; z-index:200;
      display:flex; align-items:center; justify-content:space-between;
      padding:18px 32px; background:rgba(6,5,10,.92);
      backdrop-filter:blur(14px); border-bottom:1px solid rgba(255,255,255,.04);
    }
    .nav-logo { display:flex; align-items:center; gap:12px; text-decoration:none; }
    .nav-logo img { width:34px; height:34px; border-radius:50%; filter:drop-shadow(0 0 6px rgba(201,162,39,.3)); }
    .nav-logo span { font-family:'Cormorant Garamond',serif; font-size:1.05rem; letter-spacing:4px; color:var(--white); }
    .nav-logo span b { color:var(--gold-light); font-weight:400; }
    .nav-back { font-size:.52rem; letter-spacing:4px; text-transform:uppercase; color:var(--muted); text-decoration:none; transition:color .3s; }
    .nav-back:hover { color:var(--gold); }

    /* LOADING */
    #ls {
      position:fixed; inset:0; background:var(--bg);
      display:flex; align-items:center; justify-content:center; z-index:999; transition:opacity .5s;
    }
    #ls.hide { opacity:0; pointer-events:none; }
    #ls span {
      font-size:.55rem; letter-spacing:6px; text-transform:uppercase;
      color:var(--gold); opacity:.5; animation:pulse 1.5s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:.3;} 50%{opacity:.8;} }

    /* MAIN */
    main { max-width:680px; margin:0 auto; padding:110px 24px 80px; }

    @keyframes fadeUp { from{opacity:0;transform:translateY(16px);} to{opacity:1;transform:translateY(0);} }

    /* HEADER */
    .page-header { margin-bottom:48px; animation:fadeUp .8s ease both; }
    .page-eyebrow { font-size:.5rem; letter-spacing:6px; text-transform:uppercase; color:var(--purple-lt); opacity:.7; margin-bottom:12px; }
    .page-title { font-family:'Cormorant Garamond',serif; font-weight:300; font-size:2.4rem; letter-spacing:3px; line-height:1.1; }
    .page-title em { font-style:italic; color:var(--gold-light); }
    .page-sub { font-size:.62rem; letter-spacing:3px; text-transform:uppercase; color:var(--muted); margin-top:14px; line-height:2; }

    /* PROGRESS */
    .progress-wrap { margin-bottom:40px; animation:fadeUp .6s .1s ease both; opacity:0; }
    .progress-row {
      display:flex; justify-content:space-between;
      font-size:.5rem; letter-spacing:4px; text-transform:uppercase;
      color:var(--muted); margin-bottom:8px;
    }
    .progress-bar { height:2px; background:rgba(255,255,255,.05); border-radius:2px; overflow:hidden; }
    .progress-fill {
      height:100%;
      background:linear-gradient(90deg, var(--purple), var(--gold-light));
      border-radius:2px; transition:width .8s cubic-bezier(.25,1,.5,1);
    }

    /* PILAR SECTIONS */
    .pilar-section { margin-bottom:36px; animation:fadeUp .6s ease both; opacity:0; }
    .pilar-label {
      font-size:.5rem; letter-spacing:5px; text-transform:uppercase;
      color:var(--purple-lt); opacity:.6; margin-bottom:14px;
      display:flex; align-items:center; gap:12px;
    }
    .pilar-label::after { content:''; flex:1; height:1px; background:linear-gradient(90deg, var(--purple-border), transparent); }

    /* APOSTILA BUTTON */
    .apostila-btn {
      width:100%; display:flex; align-items:center; justify-content:space-between;
      padding:18px 22px; margin-bottom:6px; border-radius:2px;
      background:var(--card); border:1px solid rgba(255,255,255,.05);
      cursor:pointer; transition:all .3s ease; position:relative; overflow:hidden;
      text-align:left;
    }
    .apostila-btn::after {
      content:''; position:absolute; bottom:0; left:0;
      width:0; height:1px;
      background:linear-gradient(90deg, var(--purple-lt), var(--gold), transparent);
      transition:width .5s;
    }
    .apostila-btn:hover { border-color:var(--purple-border); background:rgba(124,77,189,.04); }
    .apostila-btn:hover::after { width:100%; }
    .apostila-btn.concluida { border-color:rgba(74,222,128,.12); background:rgba(74,222,128,.02); }
    .apostila-btn.concluida::before {
      content:''; position:absolute; left:0; top:0; bottom:0; width:2px;
      background:rgba(74,222,128,.5);
    }

    .ap-left { display:flex; align-items:center; gap:14px; }
    .ap-num {
      width:34px; height:34px; border-radius:50%; flex-shrink:0;
      border:1px solid var(--purple-border);
      display:flex; align-items:center; justify-content:center;
      font-family:'Cormorant Garamond',serif; font-size:.9rem; color:var(--purple-lt);
      background:rgba(124,77,189,.06);
    }
    .apostila-btn.concluida .ap-num {
      border-color:rgba(74,222,128,.3); color:rgba(74,222,128,.8);
      background:rgba(74,222,128,.05);
    }
    .ap-title { font-family:'Cormorant Garamond',serif; font-size:1rem; letter-spacing:1.5px; }
    .ap-status {
      font-size:.42rem; letter-spacing:3px; text-transform:uppercase;
      margin-top:3px;
    }
    .ap-status.pending { color:var(--muted); }
    .ap-status.done { color:rgba(74,222,128,.7); }
    .ap-arrow { font-size:.8rem; color:var(--purple-lt); opacity:.5; flex-shrink:0; }

    /* ═══════════════════════════════
       MODAL APOSTILA
    ═══════════════════════════════ */
    .modal-overlay {
      position:fixed; inset:0; z-index:500;
      background:rgba(4,3,9,.88); backdrop-filter:blur(16px);
      display:flex; align-items:flex-end; justify-content:center;
      opacity:0; pointer-events:none; transition:opacity .4s;
    }
    .modal-overlay.open { opacity:1; pointer-events:all; }

    .modal {
      width:100%; max-width:640px; max-height:92vh;
      background:linear-gradient(160deg, #0e0a1f 0%, #09071a 100%);
      border:1px solid var(--purple-border); border-bottom:none;
      border-radius:16px 16px 0 0; overflow:hidden;
      display:flex; flex-direction:column;
      transform:translateY(100%); transition:transform .5s cubic-bezier(.16,1,.3,1);
    }
    .modal-overlay.open .modal { transform:translateY(0); }

    /* Corners */
    .modal::before {
      content:''; position:absolute; top:0; left:0; width:24px; height:24px;
      border-top:2px solid rgba(166,127,220,.5); border-left:2px solid rgba(166,127,220,.5);
      border-radius:14px 0 0 0; z-index:1; pointer-events:none;
    }
    .modal::after {
      content:''; position:absolute; top:0; right:0; width:24px; height:24px;
      border-top:2px solid rgba(166,127,220,.5); border-right:2px solid rgba(166,127,220,.5);
      border-radius:0 14px 0 0; z-index:1; pointer-events:none;
    }

    /* BG glow */
    .modal-glow {
      position:absolute; inset:0; pointer-events:none; z-index:0;
      background:radial-gradient(ellipse at 20% 0%, rgba(124,77,189,.28) 0%, transparent 55%),
                 radial-gradient(ellipse at 80% 100%, rgba(201,162,39,.06) 0%, transparent 50%);
    }

    .modal-handle {
      position:relative; z-index:2; display:flex; flex-direction:column; align-items:center;
      padding:12px 24px 0; flex-shrink:0;
    }
    .modal-pill { width:40px; height:4px; border-radius:2px; background:rgba(166,127,220,.3); margin-bottom:14px; }
    .modal-toprow {
      width:100%; display:flex; align-items:center; justify-content:space-between;
      padding-bottom:14px; border-bottom:1px solid rgba(166,127,220,.1);
    }
    .modal-badge { font-size:.42rem; letter-spacing:4px; text-transform:uppercase; color:rgba(166,127,220,.55); }
    .modal-close {
      width:32px; height:32px; border-radius:50%;
      border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.03);
      display:flex; align-items:center; justify-content:center;
      cursor:pointer; color:var(--muted); font-size:.85rem; transition:all .25s;
    }
    .modal-close:hover { background:rgba(166,127,220,.14); border-color:rgba(166,127,220,.4); color:var(--purple-lt); }

    /* Scrollable body */
    .modal-body {
      position:relative; z-index:2; overflow-y:auto; flex:1;
      padding:24px 26px 36px;
      scrollbar-width:thin; scrollbar-color:rgba(166,127,220,.2) transparent;
    }
    .modal-body::-webkit-scrollbar { width:4px; }
    .modal-body::-webkit-scrollbar-thumb { background:rgba(166,127,220,.2); border-radius:2px; }

    /* Modal num + title */
    .modal-num { font-size:.45rem; letter-spacing:5px; text-transform:uppercase; color:var(--purple-lt); opacity:.55; display:block; margin-bottom:10px; }
    .modal-title {
      font-family:'Cormorant Garamond',serif; font-weight:400;
      font-size:1.8rem; letter-spacing:2px; line-height:1.15;
      color:var(--white); margin-bottom:20px;
    }
    .modal-title em { font-style:italic; color:var(--gold-light); }

    /* Divider */
    .modal-div { display:flex; align-items:center; gap:12px; margin-bottom:22px; }
    .modal-div-line { flex:1; height:1px; background:linear-gradient(90deg,transparent,var(--gold-border),transparent); }
    .modal-div-sym { font-size:.6rem; color:var(--gold); opacity:.4; }

    /* Apostila text content */
    .apostila-content {
      font-family:'Cormorant Garamond',serif; font-size:1.05rem;
      line-height:1.95; letter-spacing:.4px; color:rgba(245,240,232,.75);
      margin-bottom:28px;
    }
    .apostila-content p { margin-bottom:14px; }
    .apostila-content strong { color:var(--gold-light); font-weight:500; }

    /* Perguntas da apostila */
    .perguntas-label {
      font-size:.48rem; letter-spacing:5px; text-transform:uppercase;
      color:var(--gold); opacity:.6; margin-bottom:14px;
      display:flex; align-items:center; gap:10px;
    }
    .perguntas-label::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,var(--gold-border),transparent); }

    .pergunta-item { margin-bottom:18px; }
    .pergunta-txt {
      font-family:'Cormorant Garamond',serif; font-size:1rem;
      letter-spacing:.5px; line-height:1.6; color:var(--white); margin-bottom:10px;
    }
    textarea.resposta {
      width:100%; background:rgba(255,255,255,.025);
      border:1px solid rgba(255,255,255,.07); border-radius:2px;
      padding:14px 16px; color:var(--white);
      font-family:'Josefin Sans',sans-serif; font-weight:300;
      font-size:.8rem; line-height:1.8; letter-spacing:.3px;
      resize:vertical; min-height:100px; outline:none; transition:border-color .3s;
    }
    textarea.resposta:focus { border-color:var(--purple-border); }

    /* Actions */
    .modal-actions { display:flex; gap:10px; flex-wrap:wrap; margin-top:26px; }
    .btn-salvar {
      background:none; border:1px solid var(--purple-border); border-radius:2px;
      padding:12px 26px; color:var(--purple-lt);
      font-family:'Josefin Sans',sans-serif; font-size:.55rem;
      letter-spacing:4px; text-transform:uppercase; cursor:pointer; transition:all .3s;
    }
    .btn-salvar:hover { background:rgba(124,77,189,.15); border-color:rgba(166,127,220,.7); }
    .btn-enviar-wpp {
      background:linear-gradient(135deg,rgba(37,211,102,.18),rgba(37,211,102,.08));
      border:1px solid rgba(37,211,102,.4); border-radius:2px;
      padding:12px 26px; color:#25d366;
      font-family:'Josefin Sans',sans-serif; font-size:.55rem;
      letter-spacing:4px; text-transform:uppercase; cursor:pointer; transition:all .3s;
      display:flex; align-items:center; gap:8px;
    }
    .btn-enviar-wpp:hover { background:rgba(37,211,102,.2); border-color:rgba(37,211,102,.7); }
    .btn-enviar-wpp svg { width:14px; height:14px; fill:#25d366; }
    .save-status { font-size:.5rem; letter-spacing:3px; text-transform:uppercase; color:var(--muted); display:flex; align-items:center; }

    /* TOAST */
    .toast {
      position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(20px);
      background:rgba(10,9,16,.96); border:1px solid var(--gold-border);
      padding:10px 24px; font-size:.5rem; letter-spacing:3px; text-transform:uppercase;
      color:var(--white); opacity:0; transition:all .35s; pointer-events:none; z-index:9999;
      white-space:nowrap;
    }
    .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

    .d1{animation-delay:.1s} .d2{animation-delay:.2s} .d3{animation-delay:.3s}
    .d4{animation-delay:.4s} .d5{animation-delay:.5s}
  </style>
</head>

  // Swipe down para fechar
  const modal = document.getElementById('modal');
  let startY = 0;
  modal.addEventListener('touchstart', e => { startY = e.touches[0].clientY; }, { passive:true });
  modal.addEventListener('touchmove', e => {
    if (document.getElementById('modalBody').scrollTop > 0) return;
    const dy = e.touches[0].clientY - startY;
    if (dy > 0) modal.style.transform = `translateY(${dy}px)`;
  }, { passive:true });
  modal.addEventListener('touchend', e => {
    const dy = e.changedTouches[0].clientY - startY;
    if (dy > 80) fecharModal();
    modal.style.transform = '';
  });

  // ── Auto-save com debounce ───────────────────────────
  window.autoSave = () => {
    clearTimeout(saveTimer);
    const status = document.getElementById('saveStatus');
    if (status) status.textContent = '...';
    saveTimer = setTimeout(() => salvarRespostas(true), 1500);
  };

  // ── Salvar respostas ─────────────────────────────────
  window.salvarRespostas = async (silencioso = false) => {
    if (!currentUser || !apostilaAtiva) return;
    const num = apostilaAtiva.num;
    const respostas = {};
    apostilaAtiva.perguntas.forEach((_, i) => {
      const el = document.getElementById(`resp_q${i+1}`);
      respostas[`q${i+1}`] = el ? el.value : '';
    });

    respostasGlobais[`apostila_${num}`] = respostas;

    await setDoc(
      doc(db, `apostilas/${currentUser.uid}/respostas/todas`),
      { ...respostasGlobais, atualizado_em: serverTimestamp() },
      { merge: true }
    );

    const status = document.getElementById('saveStatus');
    if (status) status.textContent = '✓ Salvo';
    if (!silencioso) toast('✓ Respostas salvas');
    setTimeout(() => { if (status) status.textContent = ''; }, 2000);
  };

  // ── Enviar respostas ao WhatsApp ─────────────────────
  window.enviarWpp = async () => {
    if (!currentUser || !apostilaAtiva) return;
    await salvarRespostas(true);

    const ap = apostilaAtiva;
    const nome = currentUser.displayName || currentUser.email || 'Mentorando';

    let msg = `✦ APOSTILA ${ap.num} — ${ap.titulo.toUpperCase()}\n`;
    msg += `Mentorando: ${nome}\n`;
    msg += `━━━━━━━━━━━━━━━━━━━━━━\n\n`;

    ap.perguntas.forEach((q, i) => {
      const el = document.getElementById(`resp_q${i+1}`);
      const resp = el ? el.value.trim() : '';
      msg += `❓ ${q}\n`;
      msg += `✍️ ${resp || '(sem resposta ainda)'}\n\n`;
    });

    msg += `━━━━━━━━━━━━━━━━━━━━━━\nakashahub.com.br ✦`;

    window.open(`https://wa.me/${WPP_NUM}?text=${encodeURIComponent(msg)}`, '_blank');
  };

  // ── Helpers ──────────────────────────────────────────
  function getRespostas(num) {
    return respostasGlobais[`apostila_${num}`] || {};
  }
  function escHtml(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function toast(msg, d=3000) {
    const el = document.getElementById('toast');
    el.textContent = msg; el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), d);
  }
</script>
</body>
</html>

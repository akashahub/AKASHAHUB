    currentUser = user;

    // Verificar se tem mentoria
    const snapUser = await getDoc(doc(db, "users", user.uid));
    const ud = snapUser.exists() ? snapUser.data() : {};
    if (!ud.tem_mentoria) { window.location.href = '/sessoes/'; return; }

    // Carregar respostas salvas
    const snapResp = await getDoc(doc(db, `apostilas/${user.uid}/respostas/todas`));
    if (snapResp.exists()) respostasGlobais = snapResp.data();

    renderApostilas();
    document.getElementById('ls').classList.add('hide');
  });

  // ── Renderizar apostilas ─────────────────────────────
  function renderApostilas() {
    const container = document.getElementById('apostilasContainer');
    container.innerHTML = '';

    let concluidas = 0;
    const pilares = {};

    APOSTILAS.forEach(ap => {
      if (!pilares[ap.pilar]) pilares[ap.pilar] = [];
      const respostas = getRespostas(ap.num);
      const temResposta = ap.perguntas.every((_, i) => (respostas[`q${i+1}`] || '').trim());
      if (temResposta) concluidas++;
      pilares[ap.pilar].push({ ...ap, temResposta });
    });

    // Progress
    document.getElementById('progressText').textContent = `${concluidas} / 25`;
    document.getElementById('progressFill').style.width = `${(concluidas/25)*100}%`;

    const delays = ['.d1','.d2','.d3','.d4','.d5'];
    let pilarIdx = 0;

    Object.entries(pilares).forEach(([pilarNome, aps]) => {
      const sec = document.createElement('div');
      sec.className = `pilar-section ${delays[pilarIdx % 5]}`;
      pilarIdx++;

      const label = document.createElement('div');
      label.className = 'pilar-label';
      label.textContent = pilarNome;
      sec.appendChild(label);

      aps.forEach(ap => {
        const btn = document.createElement('button');
        btn.className = `apostila-btn${ap.temResposta ? ' concluida' : ''}`;
        btn.onclick = () => abrirApostila(ap.num);
        btn.innerHTML = `
          <div class="ap-left">
            <div class="ap-num">${ap.num}</div>
            <div>
              <div class="ap-title">${ap.titulo}</div>
              <div class="ap-status ${ap.temResposta ? 'done' : 'pending'}">
                ${ap.temResposta ? '✓ Respondida' : 'Aguardando sua resposta'}
              </div>
            </div>
          </div>
          <span class="ap-arrow">›</span>
        `;
        sec.appendChild(btn);
      });

      container.appendChild(sec);
    });
  }

